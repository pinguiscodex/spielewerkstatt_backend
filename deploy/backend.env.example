DJANGO_SECRET_KEY=change-this-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=spielewerkstatt.example.com,www.spielewerkstatt.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://spielewerkstatt.example.com,https://www.spielewerkstatt.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://spielewerkstatt.example.com,https://www.spielewerkstatt.example.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_COOKIE_SECURE=true
DJANGO_TIME_ZONE=Europe/Berlin

DB_ENGINE=django.db.backends.mysql
DB_NAME=spielewerkstatt
DB_USER=spielewerkstatt
DB_PASSWORD=change-this-password
DB_HOST=127.0.0.1
DB_PORT=3306

MEDIA_ROOT=media
LEGACY_UPLOAD_ROOT=../spielewerkstatt_frontend

GUNICORN_BIND=unix:/run/spielewerkstatt/backend.sock
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
