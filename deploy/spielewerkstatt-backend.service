[Unit]
Description=Spielewerkstatt Django Backend
After=network.target mariadb.service mysql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/spielewerkstatt/spielewerkstatt_backend
EnvironmentFile=/etc/spielewerkstatt/backend.env
RuntimeDirectory=spielewerkstatt
RuntimeDirectoryMode=0755
ExecStart=/opt/spielewerkstatt/spielewerkstatt_backend/.venv/bin/gunicorn --config /opt/spielewerkstatt/spielewerkstatt_backend/deploy/gunicorn.conf.py
ExecReload=/bin/kill -HUP $MAINPID
Restart=always
RestartSec=5
KillSignal=SIGQUIT
TimeoutStopSec=30

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/spielewerkstatt/spielewerkstatt_backend/media /opt/spielewerkstatt/spielewerkstatt_backend/staticfiles /run/spielewerkstatt

[Install]
WantedBy=multi-user.target
